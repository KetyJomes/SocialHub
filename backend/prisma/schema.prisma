
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default (autoincrement())
  name String 
  email String @unique
  password String
  EDV Int @unique
  role Role

  class Class @relation("StudentClass",fields: [idClass], references: id)
  idClass Int


  PICs Class[] @relation("PicClass")

  Evaluated User_Test[] @relation("Evaluated")

  Evaluator User_Test[] @relation("Evaluator")
}


model User_Test{
  id Int @id @default(autoincrement())
  
  Evaluated User @relation("Evaluated",fields: [idEvaluated], references: [id])
  idEvaluated Int

  Evaluator User @relation("Evaluator",fields: [idEvaluator], references: [id])
  idEvaluator Int

  Tests Test @relation(fields: [idTest], references: id)
  idTest Int

  userTestAnswer Answers[]

}


model Test{
  id Int @id @default(autoincrement())
  Content String
  startDate DateTime
  finalDate DateTime
  grade Int
  type TestType
  AvaiableResult Boolean

  Skills Skill[]

  user User_Test[]
}

model Class {
  id Int @id @default (autoincrement())
  Course String
  period String
  avarageScore Int

  PIC User @relation("PicClass",fields: [idPIC], references: id)
  idPIC Int 

  students User[] @relation("StudentClass")
}

model Answers {
  id Int @id @default(autoincrement())
  value String
  scale Int

  userTestAnswer User_Test @relation(fields: [idUserTest], references: id)
  idUserTest Int

  skill Skill @relation(fields: [idSkill], references: [id])
  idSkill Int

  
}

model Skill{
  id Int @id @default(autoincrement())
  Title String
  Description String

  Tests Test @relation(fields: [idTest], references: id)
  idTest Int

  Alternative Alternatives[]
  Answer Answers[]
}

model Alternatives {
  id Int @id @default(autoincrement())
  Content String
  Scale Int

  Skills Skill @relation(fields: [idSkill], references: [id])
  idSkill Int

}



enum TestType {
  Self
  Instructor
  Group
}


enum Role {
  Student
  Leader
  ADM
  Manager
}


