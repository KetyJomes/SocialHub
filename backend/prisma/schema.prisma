
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default (autoincrement())
  name String 
  email String
  password String
  EDV Int @unique
  role Role

  class Class @relation("StudentClass",fields: [idClass], references: id)
  idClass Int


  PICs Class[] @relation("PicClass")

  Evaluated User_Test[] @relation("Evaluated")

  Evaluator User_Test[] @relation("Evaluator")
}


model User_Test{
  id Int @id @default(autoincrement())
  
  Evaluated User @relation("Evaluated",fields: [idEvaluated], references: [id])
  idEvaluated Int

  Evaluator User @relation("Evaluator",fields: [idEvaluator], references: [id])
  idEvaluator Int

  Tests Test @relation(fields: [idTest], references: id)
  idTest Int

  userTestAnswer Answers @relation(fields: [idAnswer], references: id)
  idAnswer Int

}


model Test{
  id Int @id @default(autoincrement())
  Content String
  Date DateTime
  Grade Int
  Type TestType

  Skills Skill @relation(fields: [idSkill], references: [id])
  idSkill Int

  user User_Test[]
}


model Class {
  id Int @id @default (autoincrement())
  Course String
  period String
  avarageScore Int

  PIC User @relation("PicClass",fields: [idPIC], references: id)
  idPIC Int 

  students User[] @relation("StudentClass")
}

model Answers {
  id Int @id @default(autoincrement())
  value String
  scale Scale

  userTestAnswer User_Test[]
  Skills Skill[]
  
}

model Skill{
  id Int @id @default(autoincrement())
  Title String
  Description String

  answers Answers @relation(fields: [idAnswer], references: id)
  idAnswer Int

  Alternative Alternatives @relation(fields: [idAlternative], references: id)
  idAlternative Int

  Tests Test[]
}

model Alternatives {
  id Int @id @default(autoincrement())
  Content String
  Scale Int

  Skills Skill[]

}



enum TestType {
  Self
  Instructor
  Group
}


enum Role {
  Student
  Leader
  ADM
  Manager
}

